{
  "expo": {
    "name": "ClinLab AI Assist",
    "slug": "clinlab-ai-assist",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./public/favicon.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/40eba1e0-ba19-4db7-b4e4-b5985dfdd683"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.clinlab.aiassist",
      "infoPlist": {
        "NSUserNotificationUsageDescription": "ClinLab uses notifications to alert you about pending approvals and clinical updates in real time."
      }
    },
    "android": {
      "package": "com.clinlab.aiassist",
      "adaptiveIcon": {
        "foregroundImage": "./public/favicon.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./public/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./public/favicon.png",
          "color": "#0EA5E9",
          "defaultChannel": "clinlab-alerts",
          "sounds": []
        }
      ],
      "expo-status-bar",
      [
        "expo-image-picker",
        {
          "photosPermission": "ClinLab needs access to your photo library so you can upload a profile picture."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "40eba1e0-ba19-4db7-b4e4-b5985dfdd683"
      }
    },
    "owner": "venkatasaipradeepreddyp"
  }
}
